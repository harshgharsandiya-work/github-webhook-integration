// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GithubEvent {
  id         String   @id @default(cuid())
  githubId   String   @unique // GitHub's unique delivery ID (x-github-delivery header)
  eventType  String // 'pull_request' 'issues' 'push'
  action     String? // 'open' 'closed' 
  sender     String // github username who triggered the event
  repoName   String //repo name
  payload    Json //complete raw json payload from github
  receivedAt DateTime @default(now())

  @@index([eventType])
  @@index([repoName])
}
